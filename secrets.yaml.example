# Copy to secrets.yaml and fill in values. secrets.yaml is gitignored.

wifi_ssid: "your-wifi-ssid"
wifi_password: "your-wifi-password"

# Generate with:  openssl rand -base64 32
api_encryption_key: "REPLACE_WITH_BASE64_32_BYTES"

# Any non-empty string. Used for ESPHome OTA flashing.
ota_password: "REPLACE_WITH_OTA_PASSWORD"

# Optional: fallback hotspot password when STA fails.
ap_password: "REPLACE_WITH_AP_FALLBACK_PASSWORD"

# --- Home Assistant deploy target (used by scripts/deploy-ha.sh) ---
# Tailscale/LAN address of the HA box. SSH addon must be enabled with this
# user authorized for password-less login.
ha_host: "100.x.x.x"
ha_user: "root"
# Long-lived access token: HA → Profile → Security → Long-Lived Access Tokens.
ha_token: "PASTE_LONG_LIVED_ACCESS_TOKEN_HERE"
# Optional: HTTPS endpoint when the Tailscale addon's
# `share_homeassistant: serve` mode is on (port 443, valid Let's Encrypt
# cert via Tailscale's own ACME). When set, scripts/deploy-ha.sh prints
# this URL in the "Deploy complete" message so you don't accidentally
# bookmark the plain-HTTP :8123 form. Leave blank to keep the LAN URL.
ha_https_url: ""

# JK BMS Bluetooth MAC. Find by flashing once with a placeholder and
# watching the [ble_advert] log lines for the device matching the
# Bluetooth name shown in the JK app.
bms_mac_address: "AA:BB:CC:DD:EE:FF"

# --- Easun inverter ESP (inverter/easun.yaml) ---
# Separate keys so each device's API channel is independently encrypted.
# Generate fresh: openssl rand -base64 32
easun_api_encryption_key: "REPLACE_WITH_BASE64_32_BYTES"
easun_ota_password: "REPLACE_WITH_OTA_PASSWORD"
