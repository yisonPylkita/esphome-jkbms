secrets.yaml
.esphome/
build/
*.bin
.DS_Store
__pycache__/
.venv/

# Tooling installed by scripts/setup.sh (Node.js binary, etc.)
.tools/

# npm dev dependencies (prettier) — pulled by `scripts/setup.sh`, not
# committed. package-lock.json IS committed so checkouts are reproducible.
node_modules/

# Lighthouse / audit / report artefacts — keep them out of source.
*.pdf

# Backup files made by deploy script or manual edits.
*.bak.*

# Dashboard with embedded HA token — local-only, never commit.
dashboard/*.local.html
# Ignore everything under .claude/ (worktrees, caches, local config) EXCEPT
# the agents/ subdir, which holds tracked subagent definitions consumed
# by Claude Code (see AGENTS.md → "Subagent index").
.claude/*
!.claude/agents/
