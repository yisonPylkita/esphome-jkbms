# SPDX-License-Identifier: MIT AND Apache-2.0
# SPDX-FileCopyrightText: 2026 Wojciech Bartnik
# SPDX-FileCopyrightText: Sebastian Muszynski and contributors to syssi/esphome-jk-bms
#
# JK-PB2A16S20P over BLE -> ESP32-C3 Super Mini -> Home Assistant.
#
# Protocol: JK02_32S. PB-series with firmware v14+ uses the JK02_32S BLE
# protocol; the upstream component decodes the PB-specific fields (smart
# sleep voltage, RCV/RFV, etc.) inside that frame.
#
# Modbus / RS485 backup configs:
#   - jk-pb-bms.full.yaml.bak       full Modbus config (1800 lines)
#   - jk-pb-bms.modbus-debug.yaml.bak ping-only Modbus debug build
#
# Setup:
#   1. Power on BMS, open JK app, note BMS Bluetooth name (usually "JK_BMS_..." or model-named).
#   2. First flash with placeholder MAC -> on_boot dumps every BLE advert
#      to logs. Find the JK MAC (matches the name from step 1).
#   3. Put MAC into secrets.yaml as `bms_mac_address: "AA:BB:CC:DD:EE:FF"`.
#   4. Reflash. Sensors should populate within a few seconds.

substitutions:
  name: jk-pb-bms
  device_friendly_name: "JK-PB BMS"
  # JK02_32S = JK firmware v11+/PB. JK02_24S = older v6-v10. JK04 = ancient.
  protocol_version: JK02_32S

esphome:
  name: ${name}
  friendly_name: ${device_friendly_name}
  min_version: 2025.11.0
  on_boot:
    - priority: 800.0
      then:
        - logger.log:
            format: "[JKBMS] === Boot start === BLE build, protocol=${protocol_version}"
            level: INFO

esp32:
  board: esp32-c3-devkitm-1
  variant: ESP32C3
  framework:
    type: esp-idf

external_components:
  # Upstream JK BMS component. `refresh: 0s` = always pull latest @main.
  # Pin to a tag (e.g. @v2.4.0) once it works to avoid surprise breakages.
  - source: github://syssi/esphome-jk-bms@main
    refresh: 0s

logger:
  level: DEBUG
  hardware_uart: USB_SERIAL_JTAG
  logs:
    # BLE stack chatter is loud; keep it down except when debugging.
    esp32_ble_tracker: INFO
    esp32_ble_client: INFO
    component: WARN
    scheduler: WARN
    sensor: INFO
    wifi: WARN
    api: WARN

api:
  encryption:
    key: !secret api_encryption_key

ota:
  - platform: esphome
    password: !secret ota_password
    on_begin:
      then:
        # BLE and OTA both want lots of RAM/CPU on the C3 single core;
        # drop the BLE link cleanly before flashing.
        - switch.turn_off: ble_client_switch0
        - logger.log: "[JKBMS] BLE suspended for OTA"

wifi:
  ssid: !secret wifi_ssid
  password: !secret wifi_password
  min_auth_mode: WPA2
  power_save_mode: NONE
  fast_connect: true
  output_power: 8.5
  ap:
    ssid: "${device_friendly_name} Fallback"
    password: !secret ap_password

captive_portal:

web_server:
  port: 80
  version: 3

# ---- BLE stack ----
esp32_ble_tracker:
  scan_parameters:
    # Passive scan is enough; saves power and avoids interfering with
    # active sessions when the JK app is also connected.
    active: false
  on_ble_advertise:
    # Logs every nearby BLE device. Use this on first flash to find the
    # JK BMS MAC. Once you have the MAC in secrets, you can comment
    # this whole on_ble_advertise block to quiet the log.
    - then:
        - lambda: |-
            ESP_LOGI("ble_advert", "Seen %s  RSSI=%d  Name=\"%s\"",
                     x.address_str().c_str(), x.get_rssi(),
                     x.get_name().c_str());

ble_client:
  - mac_address: "C8:47:80:2B:46:E3"
    id: client0

# ---- JK BMS BLE component ----
jk_bms_ble:
  - ble_client_id: client0
    protocol_version: ${protocol_version}
    # Throttle = min interval between published states. BMS pushes at
    # ~1 Hz over BLE; lower than 1s won't get more frames, just gates
    # re-publishing identical ones. 1s = match BMS native cadence.
    throttle: 1s
    id: bms0

# ---- entities (read-only subset for first-light) ----
binary_sensor:
  - platform: jk_bms_ble
    balancing:
      name: "balancing"
    charging:
      name: "charging"
    discharging:
      name: "discharging"
    online_status:
      name: "online status"

switch:
  # Toggle BLE link from HA. Off during OTA (see ota.on_begin above).
  - platform: ble_client
    ble_client_id: client0
    id: ble_client_switch0
    name: "${device_friendly_name} BLE enable"

sensor:
  # ---- diagnostics ----
  - platform: wifi_signal
    name: "${device_friendly_name} WiFi Signal"
    update_interval: 60s

  - platform: uptime
    name: "${device_friendly_name} Uptime"

  - platform: internal_temperature
    name: "${device_friendly_name} Internal Temperature"

  # ---- pack-level ----
  - platform: jk_bms_ble
    jk_bms_ble_id: bms0
    total_voltage:
      name: "total voltage"
    current:
      name: "current"
    power:
      name: "power"
    charging_power:
      name: "charging power"
    discharging_power:
      name: "discharging power"
    state_of_charge:
      name: "state of charge"
    capacity_remaining:
      name: "capacity remaining"
    total_battery_capacity_setting:
      name: "total battery capacity"
    charging_cycles:
      name: "charging cycles"
    delta_cell_voltage:
      name: "delta cell voltage"
    average_cell_voltage:
      name: "average cell voltage"
    min_cell_voltage:
      name: "min cell voltage"
    max_cell_voltage:
      name: "max cell voltage"
    min_voltage_cell:
      name: "min voltage cell"
    max_voltage_cell:
      name: "max voltage cell"
    temperature_sensor_1:
      name: "temperature sensor 1"
    temperature_sensor_2:
      name: "temperature sensor 2"
    power_tube_temperature:
      name: "power tube temperature"
    balancing_current:
      name: "balancing current"

  # ---- per-cell voltages (16S) ----
  - platform: jk_bms_ble
    jk_bms_ble_id: bms0
    cell_voltage_1:
      name: "cell voltage 1"
    cell_voltage_2:
      name: "cell voltage 2"
    cell_voltage_3:
      name: "cell voltage 3"
    cell_voltage_4:
      name: "cell voltage 4"
    cell_voltage_5:
      name: "cell voltage 5"
    cell_voltage_6:
      name: "cell voltage 6"
    cell_voltage_7:
      name: "cell voltage 7"
    cell_voltage_8:
      name: "cell voltage 8"
    cell_voltage_9:
      name: "cell voltage 9"
    cell_voltage_10:
      name: "cell voltage 10"
    cell_voltage_11:
      name: "cell voltage 11"
    cell_voltage_12:
      name: "cell voltage 12"
    cell_voltage_13:
      name: "cell voltage 13"
    cell_voltage_14:
      name: "cell voltage 14"
    cell_voltage_15:
      name: "cell voltage 15"
    cell_voltage_16:
      name: "cell voltage 16"

text_sensor:
  - platform: wifi_info
    ip_address:
      id: wifi_ip_text
      name: "${device_friendly_name} IP Address"
    ssid:
      id: wifi_ssid_text
      name: "${device_friendly_name} SSID"

  - platform: jk_bms_ble
    jk_bms_ble_id: bms0
    errors:
      name: "errors"
    operation_status:
      name: "operation status"
    charge_status:
      name: "charge status"
    total_runtime_formatted:
      name: "total runtime formatted"
    software_version:
      name: "software version"
    hardware_version:
      name: "hardware version"

button:
  - platform: restart
    name: "${device_friendly_name} Restart"

  - platform: factory_reset
    name: "${device_friendly_name} Factory Reset"
    entity_category: diagnostic
