# SPDX-License-Identifier: MIT AND Apache-2.0
# SPDX-FileCopyrightText: 2026 Wojciech Bartnik
#
# DEBUG / PING-ONLY build for JK-PB2A16S20P over RS485.
# Goal: send one Modbus read, see exact TX and RX bytes, isolate why
# CRC / no-response is happening. Full sensor map is preserved in
# jk-pb-bms.full.yaml.bak — restore that file when comms work.
#
# What this does:
#   - reads ONE register (0x1290 total voltage) every 10s
#   - logger -> VERY_VERBOSE on `modbus` so TX and RX bytes get dumped
#   - UART debug callback -> hex dump of every byte both directions
#   - manual "ping" button to trigger one read on demand
#   - command_throttle bumped to 200ms (50ms is tight for some JK firmware)

substitutions:
  name: jk-pb-bms
  device_friendly_name: "JK-PB BMS"
  device_addr: "1"
  uart_tx_pin: GPIO21
  uart_rx_pin: GPIO20
  flow_control_pin: GPIO10

esphome:
  name: ${name}
  friendly_name: ${device_friendly_name}
  min_version: 2025.11.0
  on_boot:
    - priority: 800.0
      then:
        - logger.log:
            format: "[JKBMS] === Boot start === DEBUG/PING build"
            level: INFO

esp32:
  board: esp32-c3-devkitm-1
  variant: ESP32C3
  framework:
    type: esp-idf

logger:
  level: VERY_VERBOSE
  hardware_uart: USB_SERIAL_JTAG
  logs:
    # keep the noise down so the modbus dump stays readable
    component: WARN
    scheduler: WARN
    sensor: INFO
    wifi: WARN
    api: WARN
    api.service: WARN
    mdns: WARN
    web_server: WARN
    web_server_idf: WARN
    network: WARN
    captive_portal: WARN
    light: WARN
    # the actually interesting ones
    modbus: VERY_VERBOSE
    modbus_controller: VERBOSE
    uart_debug: VERY_VERBOSE
    uart: INFO

api:
  encryption:
    key: !secret api_encryption_key

ota:
  - platform: esphome
    password: !secret ota_password

wifi:
  ssid: !secret wifi_ssid
  password: !secret wifi_password
  min_auth_mode: WPA2
  power_save_mode: NONE
  fast_connect: true
  output_power: 8.5
  ap:
    ssid: "${device_friendly_name} Fallback"
    password: !secret ap_password

captive_portal:

web_server:
  port: 80
  version: 3

uart:
  - id: uart_0
    baud_rate: 115200
    tx_pin: ${uart_tx_pin}
    rx_pin: ${uart_rx_pin}
    rx_buffer_size: 384
    # Dump every byte both directions in hex. This is what shows you
    # whether bytes are even reaching RX, and whether they look like a
    # valid Modbus reply (starts with 01 03 ...).
    debug:
      direction: BOTH
      dummy_receiver: false
      after:
        delimiter: "\n"
        timeout: 50ms
      sequence:
        - lambda: |-
            UARTDebug::log_hex(direction, bytes, ' ');

modbus:
  - id: modbus0
    uart_id: uart_0
    # MAX3485 = manual direction. DE/RE tied -> HIGH=TX, LOW=RX.
    # If the breakout drives DE through an inverting buffer, flip
    # `inverted: true` and reflash.
    flow_control_pin:
      number: ${flow_control_pin}
      inverted: false
    send_wait_time: 500ms

modbus_controller:
  - id: bms0
    address: ${device_addr}
    modbus_id: modbus0
    setup_priority: -10
    update_interval: 10s
    command_throttle: 200ms

sensor:
  # ONE read. 0x1290 = BatVol (UINT32, mV). Always populated on JK-PB.
  # Expected TX:  01 03 12 90 00 04 <crc_lo> <crc_hi>
  # Expected RX:  01 03 08 <4 bytes> <4 bytes pad/value> <crc_lo> <crc_hi>
  #               (JK packs values without gaps — see upstream notes)
  - platform: modbus_controller
    modbus_controller_id: bms0
    id: total_voltage
    name: "total voltage"
    address: 0x1290
    register_type: holding
    value_type: U_DWORD
    register_count: 4
    response_size: 4
    unit_of_measurement: "V"
    device_class: voltage
    state_class: measurement
    accuracy_decimals: 3
    filters:
      - multiply: 0.001

  # diagnostics so HA still shows the device is alive
  - platform: wifi_signal
    name: "${device_friendly_name} WiFi Signal"
    update_interval: 60s

  - platform: uptime
    name: "${device_friendly_name} Uptime"

button:
  # Press from HA / web UI -> fires a single fresh read of total_voltage.
  # Use this to correlate "I pressed the button at T" with the byte dump.
  - platform: template
    name: "${device_friendly_name} Ping BMS"
    on_press:
      - logger.log:
          format: "[JKBMS] === PING button pressed, triggering update ==="
          level: INFO
      - component.update: bms0

  - platform: restart
    name: "${device_friendly_name} Restart"

# Hardware diagnostic: spam TX continuously so a multimeter can see
# DE pin and A-B activity. Toggle from HA / web UI.
switch:
  - platform: template
    name: "${device_friendly_name} TX SPAM (diag)"
    id: tx_spam
    optimistic: true
    turn_on_action:
      - logger.log: "TX SPAM enabled"
    turn_off_action:
      - logger.log: "TX SPAM disabled"

interval:
  - interval: 50ms
    then:
      - if:
          condition:
            switch.is_on: tx_spam
          then:
            - component.update: bms0
